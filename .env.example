# Cluster and TxLINE
SOLANA_CLUSTER=devnet                 # devnet | mainnet-beta  (safety toggle)
TXLINE_API_BASE=https://txline-dev.txodds.com/api/
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_SERVICE_WALLET_SECRET=...      # server-side only
TXLINE_SERVICE_LEVEL_ID=1             # only row 1 exists on devnet's live pricing_matrix, not 12
TXLINE_SUBSCRIPTION_WEEKS=4           # program enforces weeks % 4 === 0
TXLINE_SUBSCRIBE_TX_SIG=...           # output of `pnpm --filter @sixth-sense/txline subscribe`
TXLINE_API_TOKEN=...                  # cached from token/activate — it's single-use per txSig, don't re-activate
SIXTH_SENSE_PROGRAM_ID=...            # our Anchor program (per cluster)

# Replay Mode (Section 12)
REPLAY_FIXTURE_ID=...                 # cache one via `pnpm --filter @sixth-sense/txline cache-fixture`
# Card windows are real-match-time and compress the same way events do — a
# 45s window becomes ~1s of real reaction time at 40x, which is unplayable.
# Use 40 for a spectator/highlight-reel speed (full match in ~3-4 min);
# use something like 6 for actually playing (full match in ~22 min, but
# 7.5s-40s of real time per card depending on window length).
REPLAY_ACCELERATION=6
NEXT_PUBLIC_REPLAY_ACCELERATION=6     # must match REPLAY_ACCELERATION so the client's countdown ring ticks correctly

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=...
PRIVY_APP_SECRET=...

# Infra
DATABASE_URL=...
RELAY_WS_URL=ws://localhost:8080
NEXT_PUBLIC_RELAY_WS_URL=ws://localhost:8080

# Fee payer for sponsored settlement (devnet)
SETTLEMENT_PAYER_SECRET=...
